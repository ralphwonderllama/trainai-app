  "activity_data_rules": {
    "workout_objects_authoritative": true,
    "workout_object_fields_to_prioritize": [
      "type",
      "duration",
      "distance",
      "elevation_gain",
      "source"
    ],
    "apple_health_walking_rule": {
      "use_daily_walking_miles_only_when_workouts_empty": true,
      "on_workout_days_treat_walking_as_redundant": true,
      "do_not_double_count_walking_distance_on_workout_days": true
