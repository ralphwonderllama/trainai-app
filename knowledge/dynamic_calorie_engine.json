    ],
    "protein_g": [
      135,
      145
    ],
    "carbs_g": [
      330,
      360
    ],
    "fat_g": [
      100,
      110
    ],
    "caveat": "These likely represent better-than-average behavior because tracking causes the user to eat more."
  },
  "baseline_rules": {
    "absolute_minimum_calories_kcal": 2800,
