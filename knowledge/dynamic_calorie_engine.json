{
  "schema_version": "1.0.0",
  "purpose": "Dynamic calorie and macro recommendation rules for a personal AI nutrition/activity app.",
  "user_profile": {
    "sex": "male",
    "age": 51,
    "current_weight_lb": 147,
    "initial_goal_weight_lb": 160,
    "long_term_goal_weight_lb": 175,
    "primary_goal": "gain_lean_mass_while_training_endurance",
    "training_identity": "hybrid_athlete_active_lifter",
    "dietary_constraints": [
      "gluten_free",
      "low_lactose",
      "mostly_dairy_free"
