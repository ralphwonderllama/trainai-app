  "macro_logic": {
    "protein": {
      "target_g": [
        140,
        160
      ],
      "heavy_day_max_g": 165,
      "logic": "Keep protein relatively stable across activity levels.",
      "note": "Protein is generally adequate and is not the main limiting factor."
    },
    "carbs": {
      "primary_scaling_variable": true,
      "logic": "Increase carbs with endurance duration, elevation, consecutive training days, and recovery debt.",
      "rest_low_activity_g": [
        375,
        425
      ],
      "lift_day_g": [
        400,
        475
      ],
      "moderate_endurance_g": [
        475,
        550
      ],
      "heavy_endurance_g": [
        525,
        650
      ]
    },
    "fat": {
      "target_g": [
        90,
        130
      ],
      "logic": "Use fat to support calorie density, especially with gluten-free eating constraints."
    }
  },
  "underfueling_detection": {
    "flags": [
      {
        "condition": "calories_logged < 2800 and not intentional_restriction",
        "severity": "high",
        "message": "Likely under-fueled relative to weight-gain goal."
      },
      {
        "condition": "workout_day and calories_logged < 3000",
        "severity": "high",
        "message": "Training day ended below minimum fueling threshold."
      },
      {
        "condition": "moderate_endurance_day and calories_logged < 3500",
        "severity": "high",
        "message": "Endurance day likely under-fueled."
      },
      {
        "condition": "heavy_endurance_day and calories_logged < 3900",
        "severity": "very_high",
        "message": "Heavy endurance/elevation day likely created a deficit."
      },
      {
        "condition": "target_gap_kcal >= 300",
        "severity": "mild_to_moderate",
        "message": "Below target; add calories to preserve surplus."
      },
      {
        "condition": "target_gap_kcal >= 700",
        "severity": "high",
        "message": "Meaningful under-fueling risk."
      },
      {
        "condition": "protein_on_track and carbs_below_target_after_endurance",
        "severity": "moderate",
        "message": "Protein is fine; carbs are the main recovery gap."
      },
      {
        "condition": "no_food_logged_by_mid_afternoon and activity_load_high",
        "severity": "early_warning",
        "message": "High-risk under-eating day developing."
      }
    ]
  },
  "recovery_debt_logic": {
    "track_cumulative_deficit": true,
    "window_days": 3,
    "deficit_bands_kcal": {
      "mild": [
        300,
        500
      ],
      "meaningful": [
        500,
        900
      ],
      "high": [
        900,
        99999
      ]
    },
    "if_three_day_deficit_exceeds_kcal": 1000,
    "recommendation": "Increase calories, especially carbohydrates, over the next 24-48 hours.",
    "avoid": [
      "binge_framing",
      "shame",
      "restriction_language"
    ]
  },
  "meal_completeness_rules": {
    "likely_incomplete_if_calories_below_kcal": 1500,
    "review_needed_if_calories_between_kcal": [
      1500,
      2200
    ],
    "likely_usable_if_calories_above_kcal": 2200,
    "exclude_or_mark_incomplete_when": [
      "only_one_meal_logged",
      "breakfast_and_lunch_logged_but_dinner_missing",
      "calories_implausibly_low_without_intentional_fast_or_illness",
      "obvious_partial_logging"
    ],
    "include_when": [
      "multiple_meals_logged",
      "lunch_intentionally_skipped_but_shake_or_snack_logged",
      "day_appears_to_represent_real_intake"
    ]
  },
