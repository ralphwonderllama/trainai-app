    "gym_visit_rule": {
      "default_assumption": "weightlifting",
      "calorie_burn": "moderate",
      "recovery_demand": "meaningful",
      "notes": [
        "User reports gym visits are mostly weightlifting, not cardio."
      ]
    },
    "deduplication_rules": [
      "If multiple workout objects on same date have same type, similar distance, similar duration, and similar elevation, treat as duplicate.",
      "If Strava and AllTrails both describe the same outdoor activity, preserve the richer/elevation-aware record.",
      "Do not add Apple walking miles to recorded cycling/hiking/trail-running distance."
    ]
  },
  "behavioral_model": {
    "tracked_days": {
      "description": "User eats more intentionally when tracking and using visible calorie targets.",
      "likely_intake_range_kcal": [
        2700,
        3000
      ],
      "interpretation": "Tracked days likely overestimate normal baseline intake."
    },
    "untracked_days": {
      "description": "User tends to under-eat when not tracking.",
      "likely_intake_range_kcal": [
        2300,
        2700
      ],
      "risk": "chronic_underfueling",
      "notes": [
        "May skip meals unintentionally.",
        "May rely on protein shake for lunch.",
        "Busy/travel days are high risk."
      ]
    },
    "primary_problem": "inconsistent_caloric_surplus",
    "not_primary_problem": [
      "protein_intake",
      "food_quality",
      "abnormal_metabolism"
    ]
  },
  "estimated_complete_logged_day_averages": {
    "calories_kcal": [
      2700,
